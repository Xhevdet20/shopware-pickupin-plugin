<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

    
        <service id="PickupInStore\Service\StoreAddressService">
            <argument type="service" id="order_address.repository"/>
            <argument type="service" id="country.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        
        <service id="PickupInStore\Subscriber\OrderPlacedSubscriber">
            <argument type="service" id="PickupInStore\Service\StoreAddressService"/>
            <tag name="kernel.event_subscriber"/>
        </service>

    </services>

</container>
